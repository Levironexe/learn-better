# Supabase — from your project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase DB connections — from dashboard > Connect
# Transaction pooler (port 6543) — used by the app at runtime
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
# Direct connection (port 5432) — used by drizzle-kit for migrations only
DATABASE_URL_UNPOOLED=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Brave Search (optional — enables web search during lesson creation)
BRAVE_API_KEY=BSA...
